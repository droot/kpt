apiVersion: kpt.dev/v1alpha2
kind: Kptfile
metadata:
  name: db
pipeline:
  mutators:
  - image: gcr.io/sunilarora-sandbox/httpbin-fn:latest
  - image: gcr.io/kpt-fn/set-namespace:unstable
    configMap:
      namespace: db
  - image: gcr.io/kpt-fn/set-label:unstable
    config:
      apiVersion: v1
      kind: ConfigMap
      metadata:
        name: my-config
      data:
        labels:
        - label_name: app
          label_value: backend