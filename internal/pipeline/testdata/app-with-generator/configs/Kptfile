apiVersion: kpt.dev/v1alpha2
kind: Kptfile
metadata:
  name: app-with-generator
pipeline:
  mutators:
  - image: gcr.io/kpt-fn/set-namespace:unstable
    configMap:
      namespace: staging
  - image: gcr.io/kpt-fn/set-label:unstable
    config:
      apiVersion: v1
      kind: ConfigMap
      metadata:
        name: my-config
      data:
        labels:
        - label_name: tier
          label_value: db